VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your anon key here...

# Email of the shared helper account created in Supabase Auth.
# This is NOT secret (it ships in the bundle); the PASSWORD is what helpers type
# on the unlock screen and is verified server-side. Leave unset to use the
# default below.
VITE_HELPER_EMAIL=helpers@wedding.local

# ─── PayNow ang-bao (public "#pay" page) ──────────────────────────────────────
# The host's PayNow-linked mobile number and display name shown to guests who
# want to send a gift. NOT secret — they ship in the bundle and are visible to
# anyone who scans the QR. The mobile must be PayNow-registered with the host's
# bank. Leave VITE_PAYNOW_MOBILE unset to hide the gift QR (shows a notice).
VITE_PAYNOW_MOBILE=+6591234567
VITE_PAYNOW_NAME="The Happy Couple"

# ─── Ang-bao tracking (optional feature) ──────────────────────────────────────
# Enabled by default. Set to "false" to hide ALL ang-bao UI — the Angbaos stat
# pill, the "Angbao Tracker" tab, per-guest ang-bao toggles/amounts, the
# Submissions tab, and the public "#pay" gift page — for events where collecting
# ang-bao isn't applicable. This only hides the UI; any existing angbao data in
# the database is preserved and reappears if you re-enable the feature.
VITE_ENABLE_ANGBAO=true

# ─── Email automation (api/ serverless functions only) ────────────────────────
# These are SERVER-ONLY — set them in your Vercel project's environment
# variables, never with a VITE_ prefix (that would ship them to the browser
# bundle). They are read by api/send-rsvp-email.js and api/send-reminders.js,
# never by client code.

# Service-role key from Supabase (Project Settings → API). Bypasses RLS so the
# webhook/cron functions can read/update guest rows. Treat like a master password.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service role key here...

# From resend.com (Settings → API Keys).
RESEND_API_KEY=re_xxxxxxxxxxxx
# A domain you've verified in Resend, used as the "from" address (rsvp@<domain>).
RESEND_SENDING_DOMAIN=mail.yourdomain.com
# Optional: overrides the computed "rsvp@<domain>" from-address entirely.
# Set this to Resend's sandbox sender (onboarding@resend.dev) to test before
# verifying your own domain — note the sandbox only delivers to the email
# address your Resend account was signed up with. Leave unset once you have
# RESEND_SENDING_DOMAIN verified.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Shared secret the `guests_rsvp_status_webhook` Postgres trigger sends in the
# `x-webhook-secret` header — must match the `rsvp_email_webhook_secret` value
# created via `vault.create_secret(...)` (see supabase/migrations/0006_email_automation.sql).
RSVP_WEBHOOK_SECRET=a-long-random-string

# Set by you; Vercel Cron then sends it back as `Authorization: Bearer <value>`
# on every /api/send-reminders invocation — verified before the job runs.
CRON_SECRET=another-long-random-string
