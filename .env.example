VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your anon key here...

# Emails for the two Supabase Auth accounts. Neither is secret (they ship in
# the bundle); the PASSWORDS are what users type on the unlock screen and are
# verified server-side. Leave unset to use the defaults below.
#
# Couple account — full access (RSVP, Seating, Wedding Setup, Wishes Wrapped,
# D-Day controls, Submissions, exports).
VITE_COUPLE_EMAIL=couple@wedding.local
#
# Helper / Bridal Team account — D-Day only (guest check-in, angbao recording,
# lucky draw, read-only seating chart). Share only the PASSWORD with helpers.
# The helper's reduced access is enforced in the DB (RLS, migrations
# 0001_core.sql + 0005_roles_security.sql). If you change these emails, also update the
# matching rows in the `app_config` table so the DB agrees (see SECURITY.md).
#
# ⚠ Migration note: the default was 'helpers@wedding.local' (with an 's') before
# this was standardised to 'helper@wedding.local'. If you set up Supabase Auth
# without setting VITE_HELPER_EMAIL and used the old default, either:
#   (a) set VITE_HELPER_EMAIL=helpers@wedding.local here to keep the old address, or
#   (b) rename the Supabase Auth account to helper@wedding.local in the dashboard.
VITE_HELPER_EMAIL=helper@wedding.local

# ─── PayNow ang-bao (public "#pay" page) ──────────────────────────────────────
# The host's PayNow-linked mobile number and display name shown to guests who
# want to send a gift. NOT secret — they ship in the bundle and are visible to
# anyone who scans the QR. The mobile must be PayNow-registered with the host's
# bank. Leave VITE_PAYNOW_MOBILE unset to hide the gift QR (shows a notice).
VITE_PAYNOW_MOBILE=+6591234567
VITE_PAYNOW_NAME="The Happy Couple"

# ─── Ang-bao tracking (optional feature) ──────────────────────────────────────
# Enabled by default. Set to "false" to hide ALL ang-bao UI — the Angbaos stat
# pill, the "Angbao Tracker" tab, per-guest ang-bao toggles/amounts, the
# Submissions tab, and the public "#pay" gift page — for events where collecting
# ang-bao isn't applicable. This only hides the UI; any existing angbao data in
# the database is preserved and reappears if you re-enable the feature.
VITE_ENABLE_ANGBAO=true

# ─── Guest photowall (optional feature, #138) ─────────────────────────────────
# Guests upload photos on the public wedding page; files are stored OUTSIDE
# Supabase in external object storage, metadata stays in Postgres. Enabled by
# default at build time; the couple must also enable it (and set a PIN) in
# Wedding Setup. Set to "false" to hide ALL photowall UI.
VITE_ENABLE_PHOTOWALL=true

# ── Photo storage provider (SERVER-ONLY, set in Vercel env) ───────────────────
# Choose where guest photo FILES are stored: "r2" (Cloudflare R2, recommended —
# 10 GB free, zero egress) or "vercel-blob" (lowest setup effort, shares your
# Vercel plan's allotment). Switching is an env change — no code change needed.
# Leave unset to disable photo uploads server-side (the section hides itself).
PHOTO_STORAGE_PROVIDER=
#
# Option A: Cloudflare R2 (PHOTO_STORAGE_PROVIDER=r2)
# Create a bucket, an R2 API token (Object Read & Write), and either enable the
# bucket's public r2.dev dev URL or attach a custom domain.
# ⚠ REQUIRED: set the bucket's CORS policy to allow PUT from your site origin
#   with the "content-type" header, or browser uploads fail (see SECURITY.md).
# ⚠ If you use a CUSTOM public domain (not *.r2.dev), you must also add that
#   host to the img-src CSP directive in vercel.json.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL photos are served from (no trailing slash),
# e.g. https://pub-xxxxxxxx.r2.dev or https://photos.yourdomain.com
R2_PUBLIC_BASE_URL=
#
# Option B: Vercel Blob (PHOTO_STORAGE_PROVIDER=vercel-blob)
# Create a Blob store in the Vercel dashboard (Storage → Blob); connecting it
# to the project auto-populates this token. No CORS setup needed, but the
# browser uploads via https://vercel.com/api/blob — that host must stay in the
# connect-src CSP directive in vercel.json (it's there; don't remove it).
BLOB_READ_WRITE_TOKEN=

# ─── Email automation (api/ serverless functions only) ────────────────────────
# These are SERVER-ONLY — set them in your Vercel project's environment
# variables, never with a VITE_ prefix (that would ship them to the browser
# bundle). They are read by api/send-rsvp-email.js and api/send-reminders.js,
# never by client code.

# Service-role key from Supabase (Project Settings → API). Bypasses RLS so the
# webhook/cron functions can read/update guest rows. Treat like a master password.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service role key here...

# ── Email provider selection ──────────────────────────────────────────────────
# Choose your email provider: "gmail" (default) or "resend".
# Switching is a single env var change — no code change needed.
EMAIL_PROVIDER=gmail

# ── Option A: Resend (resend.com) ─────────────────────────────────────────────
# Requires a verified sending domain. In sandbox mode only delivers to the
# email address the Resend account was signed up with — not suitable for
# sending to real guests.
RESEND_API_KEY=re_xxxxxxxxxxxx
# A domain you've verified in Resend, used as the "from" address (rsvp@<domain>).
RESEND_SENDING_DOMAIN=mail.yourdomain.com
# Optional: overrides the computed "rsvp@<domain>" from-address entirely.
# Set to onboarding@resend.dev while testing in sandbox mode.
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Option B: Gmail via Nodemailer ────────────────────────────────────────────
# No domain required. Uses Gmail SMTP with an App Password.
# Setup: enable 2-Step Verification on your Google account →
#        go to myaccount.google.com/apppasswords → create an app password.
# Limit: 500 emails/day — more than enough for a wedding guest list.
GMAIL_FROM=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Host notifications + RSVP update links ───────────────────────────────────
# Email address that receives a notification when a guest changes their RSVP
# (confirmed → declined or declined → confirmed). First-time RSVPs are silent.
# Also receives the daily checklist reminder digest (per-task reminders set in
# the admin Checklist tab); if unset, checklist reminders are skipped.
HOST_EMAIL=yourname@gmail.com

# Public base URL of your app — used to build personalised RSVP links in emails.
# Set to your Vercel deployment URL (no trailing slash).
SITE_URL=https://your-app.vercel.app

# ── Shared secrets ────────────────────────────────────────────────────────────
# Shared secret the `guests_rsvp_status_webhook` Postgres trigger sends in the
# `x-webhook-secret` header — must match the `rsvp_email_webhook_secret` value
# created via `vault.create_secret(...)` (see supabase/migrations/0007_email_automation.sql).
RSVP_WEBHOOK_SECRET=a-long-random-string

# Set by you; Vercel Cron then sends it back as `Authorization: Bearer <value>`
# on every /api/send-reminders invocation — verified before the job runs.
CRON_SECRET=another-long-random-string

# ── Translation (optional) ────────────────────────────────────────────────────
# The Wedding Setup "Auto-translate" button proxies via /api/translate (#53, #59).
# DeepL Free (preferred, more natural) is used for supported languages when a key
# is set; otherwise, and for languages DeepL can't handle (e.g. Malay), it falls
# back to MyMemory. Both are optional — server-only, never VITE_-prefixed.
#
# DeepL Free API key (https://www.deepl.com/pro-api, 500k chars/month free).
DEEPL_API_KEY=
# DeepL endpoint. Leave blank for Free (default: https://api-free.deepl.com/v2/translate).
# For a Pro/paid key (the key does NOT end in ":fx"), set this to
# https://api.deepl.com/v2/translate — otherwise the Free host rejects it with 403.
DEEPL_API_URL=
# MyMemory: setting an email raises the anonymous daily quota (~50k words/day).
MYMEMORY_EMAIL=yourname@gmail.com

# ── AI theme generation (api/generate-theme.js, optional) ─────────────────────
# The Wedding Setup "Generate theme from an image" button (#60) sends an uploaded
# image to a vision LLM, which returns a color-only palette (the "Custom" theme).
# Server-only — NEVER VITE_-prefixed. Only authenticated helpers can call it.
# Provider is switchable: "anthropic" (default) | "openai" | "nvidia".
THEME_AI_PROVIDER=anthropic
# Set ONLY the key for your chosen provider (the couple's own API key):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
NVIDIA_API_KEY=
# Optional: override the default vision model for the chosen provider.
THEME_AI_MODEL=
# Optional, nvidia only: pin the NVIDIA NIM model to route to (#66). NVIDIA hosts
# many models and needs a valid one your key is entitled to — a wrong/unentitled
# model surfaces as a 401/403 in the logs. Takes precedence over THEME_AI_MODEL
# for the nvidia provider. Default: meta/llama-3.2-90b-vision-instruct.
NVIDIA_MODEL=

# Server-side overrides for the generate-theme endpoint auth check (optional).
# The endpoint accepts any signed-in account whose email matches EITHER the couple
# or helper email. Leave unset to fall back to the VITE_ vars above.
# COUPLE_EMAIL also tightens photowall photo DELETION (/api/photowall) to the
# couple's account specifically — when no couple email is configured anywhere,
# any authorized signed-in account (incl. the helper) can delete photos.
COUPLE_EMAIL=
HELPER_EMAIL=
