VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your anon key here...

# Email of the shared helper account created in Supabase Auth.
# This is NOT secret (it ships in the bundle); the PASSWORD is what helpers type
# on the unlock screen and is verified server-side. Leave unset to use the
# default below.
VITE_HELPER_EMAIL=helpers@wedding.local

# ─── PayNow ang-bao (public "#pay" page) ──────────────────────────────────────
# The host's PayNow-linked mobile number and display name shown to guests who
# want to send a gift. NOT secret — they ship in the bundle and are visible to
# anyone who scans the QR. The mobile must be PayNow-registered with the host's
# bank. Leave VITE_PAYNOW_MOBILE unset to hide the gift QR (shows a notice).
VITE_PAYNOW_MOBILE=+6591234567
VITE_PAYNOW_NAME="The Happy Couple"

# ─── Ang-bao tracking (optional feature) ──────────────────────────────────────
# Enabled by default. Set to "false" to hide ALL ang-bao UI — the Angbaos stat
# pill, the "Angbao Tracker" tab, per-guest ang-bao toggles/amounts, the
# Submissions tab, and the public "#pay" gift page — for events where collecting
# ang-bao isn't applicable. This only hides the UI; any existing angbao data in
# the database is preserved and reappears if you re-enable the feature.
VITE_ENABLE_ANGBAO=true
